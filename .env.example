# Core application database.
MUCKRAKE_DATABASE_URL=postgresql://myproject:secret@localhost:5432/myproject

# Optional separate published database for the API. Defaults to MUCKRAKE_DATABASE_URL.
MUCKRAKE_PUBLISHED_DATABASE_URL=postgresql://myproject:secret@localhost:5432/myproject_published

# Optional local overrides.
# MUCKRAKE_DATA_PATH=data
# MUCKRAKE_ARTIFACT_PATH=data/artifacts
# MUCKRAKE_DATASET_PATHS=../openlobbying/datasets
# MUCKRAKE_ENV_FILE=.env
# FTM_MODEL_PATH is configured automatically by muckrake to include local schema extensions.
# Set this only if you want to override that merged model path explicitly.
# FTM_MODEL_PATH=
# OPENROUTER_API_KEY=
# LLM_MODEL=
# NER_LLM_PROMPT_FILE=
# LOGFIRE_TOKEN=
