[Unit]
Description=OpenLobbying SvelteKit service
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/muckrake/openlobbying
EnvironmentFile=/etc/muckrake/web.env
ExecStart=/usr/bin/node build
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
