[Unit]
Description=Muckrake FastAPI service
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/muckrake
EnvironmentFile=/etc/muckrake/api.env
ExecStart=/home/deploy/muckrake/.venv/bin/uvicorn muckrake.api.server:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
